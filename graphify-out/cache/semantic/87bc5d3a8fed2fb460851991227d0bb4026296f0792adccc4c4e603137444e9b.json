{"nodes": [{"id": "porting_specs_technical_specification", "label": "Technical Specification", "file_type": "document", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "porting_specs_technical_specification_adr_001", "label": "ADR-001: Frontend Framework & State Management Choice", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Removed Zustand and React dependencies. All state management handled via Svelte 5 Runes ($state, $derived) and state modules to minimize memory footprint and bundle size in WKWebView."}, {"id": "porting_specs_technical_specification_adr_002", "label": "ADR-002: Local Vector Store Selection", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Selected LanceDB via native Rust lancedb crate (with sqlite-vec fallback). Operates directly within Tauri binary with Metal SIMD hardware acceleration on Apple Silicon without requiring a separate server."}, {"id": "porting_specs_technical_specification_adr_003", "label": "ADR-003: Knowledge Graph Technology", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Embedded property graph stored inside SQLite using standard graph_node and graph_edge tables, traversed via recursive CTEs. Demoted LadybugDB to Phase 2 to avoid pre-1.0 C++ bindings."}, {"id": "porting_specs_technical_specification_adr_004", "label": "ADR-004: Embedded Browser Strategy", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Use Chrome DevTools Protocol (CDP) via chromiumoxide to connect to user's existing Chrome browser, with Obscura (Rust headless browser) as offline fallback. Avoids bundling heavy Chromium Embedded Framework."}, {"id": "porting_specs_technical_specification_adr_005", "label": "ADR-005: Sync & Client-Side Conflict Resolution", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deferred Loro CRDT multi-device sync to Phase 3. Phase 1 provides simple manual backup export (SQLite dump + LanceDB vectors) and restore."}, {"id": "porting_specs_technical_specification_adr_006", "label": "ADR-006: Offline-First Subscription & Entitlement Model", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses Rust-based EntitlementService for offline JWT validation using a compile-time embedded RSA public key. Detects clock rollback using secure timestamps in Keychain."}, {"id": "porting_specs_technical_specification_adr_007", "label": "ADR-007: Local Agent Runtime Integration Architecture", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Spawns Node.js process sidecar running Pi SDK. Rust communicates with sidecar via JSON-RPC 2.0 over standard I/O (stdio). Avoids rewriting TypeScript agent SDK in Rust."}, {"id": "porting_specs_technical_specification_adr_008", "label": "ADR-008: Database Architecture & Tauri SQL Plugin Exclusion", "file_type": "rationale", "source_file": "porting-specs/technical_specification.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Excludes tauri-plugin-sql to prevent dual pool conflicts and WAL locking. Rust backend manages SQLite directly via rusqlite, exposing commands to Svelte frontend."}], "edges": [{"source": "porting_specs_technical_specification_adr_001", "target": "porting_specs_frontend_design_state_stores", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_002", "target": "porting_specs_system_design_vector_store", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_003", "target": "porting_specs_system_design_graph_engine", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_004", "target": "porting_specs_system_design_browser_client", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_005", "target": "porting_specs_system_design_backup_coordinator", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_006", "target": "porting_specs_system_design_entitlement_service", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_007", "target": "porting_specs_system_design_pi_sdk_bridge", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_007", "target": "porting_specs_system_design_pi_sdk_sidecar", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}, {"source": "porting_specs_technical_specification_adr_008", "target": "porting_specs_system_design_database_layer", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "tauri_porting_architecture_decisions", "label": "Tauri Porting Architecture Decisions", "nodes": ["porting_specs_technical_specification_adr_001", "porting_specs_technical_specification_adr_002", "porting_specs_technical_specification_adr_003", "porting_specs_technical_specification_adr_004", "porting_specs_technical_specification_adr_005", "porting_specs_technical_specification_adr_006", "porting_specs_technical_specification_adr_007", "porting_specs_technical_specification_adr_008"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "porting-specs/technical_specification.md"}]}